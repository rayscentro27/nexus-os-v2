# Nexus OS v2 — environment template. Real values go ONLY in .env (gitignored).
# Frontend may ONLY use VITE_* vars. Service role + tokens are server/script-side only.

# ── Supabase ──
# Frontend (safe to expose to the browser):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server / job runner / scripts ONLY — never expose to the browser, never commit:
SUPABASE_SERVICE_ROLE_KEY=

# ── Meta (Facebook Page + Instagram) ──
# Account IDs are public-safe; the TOKEN must never be committed.
META_PAGE_ID=131069194210954
META_PAGE_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=17841480265043148

# ── Telegram (War Room / TheChoseone) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Oanda (demo/practice only — no live trading) ──
OANDA_ENV=practice
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# ── Hermes gateway (optional live AI; falls back to snapshot) ──
HERMES_GATEWAY_URL=
HERMES_API_KEY=

# ── Hermes provider abstraction ──
# Frontend flags ONLY say whether a server-side provider endpoint exists (booleans, NOT keys).
# Leave empty/false → Hermes clearly says the chat/search provider is not configured.
VITE_HERMES_CHAT_ENABLED=false
VITE_HERMES_SEARCH_ENABLED=false
# OFF | SHADOW | RAY_ONLY_PILOT | ACTIVE. This only selects the frontend route;
# provider keys and model selection remain server-side in Supabase Edge Function secrets.
VITE_HERMES_MODEL_FIRST_MODE=OFF
#
# Chat/search API KEYS live ONLY in Supabase Edge Function secrets (server-side) — never in the
# browser, never committed. Set with: supabase secrets set KEY=... (do not put real keys in .env).
# Chat:   HERMES_CHAT_PROVIDER = openrouter | gemini | ollama   (+ HERMES_CHAT_MODEL optional)
#         OPENROUTER_API_KEY= / GEMINI_API_KEY= / OLLAMA_URL=
#         HERMES_CHAT_FALLBACK_MODEL= optional 2nd model (OpenRouter only): tried if the primary
#         model returns a non-2xx, a provider error, or an empty reply.
#         HERMES_CONTEXT_VERSION= optional cache-bust tag appended to Hermes' stable context block
#         (server-side, default "v1"); bump it after editing the stable context to refresh caching.
# Search: HERMES_SEARCH_PROVIDER = brave | tavily | serpapi
#         BRAVE_SEARCH_API_KEY= / TAVILY_API_KEY= / SERPAPI_KEY=

# ── Netlify (GitHub-connected deploy) ──
# Deploy path is push main → Netlify build (build/publish settings live in netlify.toml).
# GitHub-connected deploy does NOT need NETLIFY_AUTH_TOKEN / NETLIFY_SITE_ID — those are only for
# local Netlify CLI/API verification. To let Nexus track the live site, set the PUBLIC domain/URL
# (safe to expose; it's the public site URL, not a secret):
NEXUS_NETLIFY_PUBLIC_URL=
# Or, if you prefer a browser-exposed name (Vite-inlined): VITE_GOCLEAR_PUBLIC_URL=
# Optional CLI/API verification only:
# NETLIFY_AUTH_TOKEN=   (secret — keep out of the browser; CLI/API checks only)
# NETLIFY_SITE_ID=

# ── Misc ──
NEXUS_ENV=development
