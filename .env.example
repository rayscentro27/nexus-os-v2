# Nexus OS v2 — environment template. Real values go ONLY in .env (gitignored).
# Frontend may ONLY use VITE_* vars. Service role + tokens are server/script-side only.

# ── Supabase ──
# Frontend (safe to expose to the browser):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server / job runner / scripts ONLY — never expose to the browser, never commit:
SUPABASE_SERVICE_ROLE_KEY=

# ── Meta (Facebook Page + Instagram) ──
# Account IDs are public-safe; the TOKEN must never be committed.
META_PAGE_ID=131069194210954
META_PAGE_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=17841480265043148

# ── Telegram (War Room / TheChoseone) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Oanda (demo/practice only — no live trading) ──
OANDA_ENV=practice
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# ── Hermes gateway (optional live AI; falls back to snapshot) ──
HERMES_GATEWAY_URL=
HERMES_API_KEY=

# ── Misc ──
NEXUS_ENV=development
