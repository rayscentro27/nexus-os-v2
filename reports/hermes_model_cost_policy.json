    "primary_model": {
      "description": "Use OpenRouter/main model only for higher-value reasoning.",
      "examples": ["strategic reasoning", "complex multi-source synthesis", "business recommendation", "detailed audit explanation", "implementation plan"],
      "max_input_tokens": 6000,
      "max_output_tokens": 1200,
      "max_turns": 4
    },
    "blocked_or_gated": {
      "description": "Never direct model execution.",
      "examples": ["send email", "publish post", "charge customer", "place live trade", "submit dispute", "destructive SQL", "start/stop workers", "deploy", "run seed"]
    }
  },

  "background_jobs": {
