      "model calls inside tight loops",
      "automatic web+model chains",
      "uncontrolled loops"
    ],
    "policy": "Background jobs that need model must use cheap_model unless Ray approves. Stop after repeated failure. Log every model call."
  },

  "context_budgets": {
