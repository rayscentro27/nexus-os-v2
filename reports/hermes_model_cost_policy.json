{
  "policy": "hermes_model_cost_policy",
  "version": "1.0",
  "generated_utc": "2026-07-01T17:30:00Z",
  "summary": "Hermes model usage must be routed, capped, logged, and context-limited. The model is ONE tool in Hermes orchestration — not the only brain.",

  "routing": {
    "no_model": {
      "description": "Use local/router answer only. Most answers should be here.",
